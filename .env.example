# Copy to .env and fill in real values before deploying.

# Long random string used to sign session cookies.
# Generate with: openssl rand -hex 32
SECRET_KEY=replace-with-a-long-random-string

# Initial admin account, created only on first start (when no admin exists).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=please-change-this

# Timezone for week calculation and scheduled jobs.
TZ=Asia/Shanghai

# Cookie security. Keep true in production (served over HTTPS via nginx).
# Set false only for local http testing.
COOKIE_SECURE=true
